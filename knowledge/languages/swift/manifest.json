  "topics": [
    { "id": "overview", "title": "Swift Overview", "path": "overview.md" },
    { "id": "security", "title": "Swift Security", "path": "security.md" },
    { "id": "performance", "title": "Swift Performance", "path": "performance.md" },
    { "id": "testing", "title": "Swift Testing", "path": "testing.md" },
    { "id": "production", "title": "Swift Production", "path": "production.md" }
  ],
  "signals": {
    "project_files": ["Package.swift", "*.xcodeproj", "*.xcworkspace"],
    "test_patterns": ["Tests/", "*Tests.swift"],
