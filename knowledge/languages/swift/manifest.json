{
  "schema": "tstack-knowledge-pack/v1",
  "id": "language-swift",
  "title": "Swift Language Pack",
  "version": "0.1.0",
  "status": "draft",
  "category": "languages",
  "language": "swift",
  "audience": ["iOS engineers", "macOS engineers", "backend engineers", "technical leads"],
